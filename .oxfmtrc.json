{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": false,
  "trailingComma": "es5",
  "arrowParens": "avoid",
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist",
    "pnpm-lock.yaml",
    "lerna.json",
    "/.nx/workspace-data",
    ".thole",
    ".svelte-kit",
    "playwright-report",
    "test-results",
    "coverage"
  ]
}
