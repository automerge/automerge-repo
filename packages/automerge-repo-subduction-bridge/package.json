{
  "name": "@automerge/automerge-repo-subduction-bridge",
  "version": "2.5.2-alpha.1",
  "description": "Bridges to use automerge-repo storage and network adapters with Subduction",
  "repository": "https://github.com/automerge/automerge-repo/tree/master/packages/automerge-repo-subduction-bridge",
  "author": "Brooklyn Zelenka <hello@brooklynzelenka.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "npm-watch build"
  },
  "dependencies": {
    "@automerge/automerge-repo": "workspace:*",
    "@automerge/automerge_subduction": "file:../../../subduction/automerge_subduction_wasm"
  },
  "watch": {
    "build": {
      "patterns": "./src/**/*",
      "extensions": [
        ".ts"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
