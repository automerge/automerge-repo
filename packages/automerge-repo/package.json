{
  "name": "@automerge/automerge-repo",
  "version": "2.6.0-subduction.44",
  "description": "A repository object to manage a collection of automerge documents",
  "repository": "https://github.com/automerge/automerge-repo/tree/main/packages/automerge-repo",
  "author": "Peter van Hardenberg <pvh@pvh.ca>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:watch": "vitest --watch",
    "fuzz": "tsx fuzz/fuzz.ts",
    "prepare": "tsc"
  },
  "browser": {
    "crypto": false
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/ws": "^8.5.10",
    "@vitest/browser": "4.1.7",
    "@vitest/browser-playwright": "4.1.7",
    "http-server": "^14.1.1",
    "playwright": "^1.60.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@automerge/automerge": "catalog:",
    "@automerge/automerge-subduction": "0.16.0",
    "bs58check": "^4.0.0",
    "cbor-x": "^1.6.4",
    "debug": "^4.4.3",
    "eventemitter3": "^5.0.4",
    "fast-sha256": "^1.3.0",
    "isomorphic-ws": "^5.0.0",
    "uuid": "^14.0.0",
    "ws": "^8.21.0",
    "xstate": "^5.32.4"
  },
  "exports": {
    ".": "./dist/entrypoints/fullfat.js",
    "./slim": "./dist/entrypoints/slim.js",
    "./subduction-websocket-worker": {
      "node": "./dist/subduction/worker-websocket/worker-entry-node.js",
      "default": "./dist/subduction/worker-websocket/worker-entry.js"
    },
    "./subduction-websocket-worker-shared": "./dist/subduction/worker-websocket/worker-entry-shared.js",
    "./worker-port": "./dist/worker-port/index.js",
    "./helpers/*.js": "./dist/helpers/*.js"
  },
  "publishConfig": {
    "access": "public",
    "tag": "subduction"
  },
  "engines": {
    "node": ">=22.13"
  },
  "files": [
    "dist",
    "src"
  ]
}
