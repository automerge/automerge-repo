{
  "name": "@automerge/automerge-repo-storage-indexeddb",
  "version": "2.6.0-subduction.43",
  "description": "IndexedDB storage adapter for Automerge Repo",
  "repository": "https://github.com/automerge/automerge-repo/tree/main/packages/automerge-repo-storage-indexeddb",
  "author": "Peter van Hardenberg <pvh@pvh.ca>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "bench": "vitest run --config vitest.browser.config.ts"
  },
  "dependencies": {
    "@automerge/automerge-repo": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "tag": "subduction"
  },
  "devDependencies": {
    "@vitest/browser": "4.1.7",
    "@vitest/browser-playwright": "4.1.7",
    "playwright": "^1.60.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.13"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./worker-adapter": {
      "types": "./dist/IndexedDBWorkerStorageAdapter.d.ts",
      "default": "./dist/IndexedDBWorkerStorageAdapter.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "default": "./dist/worker.js"
    },
    "./worker-shared": {
      "types": "./dist/worker-shared.d.ts",
      "default": "./dist/worker-shared.js"
    },
    "./worker-host": {
      "types": "./dist/worker-host.d.ts",
      "default": "./dist/worker-host.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ]
}
