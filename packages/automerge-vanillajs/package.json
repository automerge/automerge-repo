{
  "name": "@automerge/vanillajs",
  "version": "2.6.0-subduction.34",
  "description": "A quick-import vanilla JS package for Automerge Repo",
  "repository": "https://github.com/automerge/automerge-repo/tree/main/packages/automerge-vanillajs",
  "author": "Peter van Hardenberg <pvh@pvh.ca>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@automerge/automerge-repo": "workspace:*",
    "@automerge/automerge-repo-network-broadcastchannel": "workspace:*",
    "@automerge/automerge-repo-network-messagechannel": "workspace:*",
    "@automerge/automerge-repo-network-websocket": "workspace:*",
    "@automerge/automerge-repo-storage-indexeddb": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": "./dist/index.js",
    "./slim": "./dist/slim.js"
  },
  "publishConfig": {
    "access": "public",
    "tag": "subduction"
  },
  "engines": {
    "node": ">=22.13"
  },
  "files": [
    "dist",
    "src"
  ]
}
