{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": true,
    "isolatedDeclarations": true,
    "composite": true,
    "pretty": true,
    "rewriteRelativeImportExtensions": true,
    "rootDir": "./src",
    "outDir": "./out"
  },
  "include": ["src"]
}
