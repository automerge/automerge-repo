{
  "name": "@automerge/automerge-repo-monorepo",
  "version": "2.6.0-alpha.0",
  "description": "Automerge Repo monorepo",
  "main": "packages/automerge-repo/dist/index.js",
  "repository": "https://github.com/automerge/automerge-repo",
  "author": "Peter van Hardenberg <pvh@pvh.ca>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev:demo": "pnpm -F @automerge/automerge-repo-demo-todo dev",
    "dev:svelte-demo": "pnpm -F @automerge/automerge-repo-demo-counter-svelte dev",
    "dev": "run-p watch start:syncserver dev:demo",
    "pub": "pnpm publish -r",
    "start:syncserver": "cross-env DEBUG='WebsocketServer' pnpm -F @automerge/example-sync-server start",
    "preinstall": "npx only-allow pnpm",
    "repocheck": "manypkg check",
    "format": "prettier --write . | dev-null",
    "lint": "prettier --check . && eslint .",
    "test": "vitest",
    "test:log": "cross-env DEBUG='automerge-repo:*' vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --coverage --ui",
    "watch": "pnpm run --parallel --stream -r watch "
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.3.0",
  "prettier": {
    "semi": false,
    "singleQuote": false,
    "trailingComma": "es5",
    "arrowParens": "avoid"
  },
  "devDependencies": {
    "@automerge/automerge": "^3.2.6",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@manypkg/cli": "^0.25.1",
    "@playwright/test": "^1.60.0",
    "@types/debug": "^4.1.13",
    "@types/node": "^22.19.19",
    "@types/react": "catalog:",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "c8": "^7.14.0",
    "cross-env": "^7.0.3",
    "dev-null-cli": "^2.0.0",
    "eslint": "^9.39.4",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "globals": "^15.15.0",
    "lerna": "^9.0.7",
    "npm-run-all": "^4.1.5",
    "npm-watch": "^0.11.0",
    "portfinder": "^1.0.38",
    "prettier": "^2.8.8",
    "ts-node": "catalog:",
    "typedoc": "^0.28.19",
    "typescript": "catalog:",
    "vite": "^7.3.3",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "happy-dom": "^20.9.0"
  }
}
