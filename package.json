{
  "name": "@automerge/automerge-repo-monorepo",
  "version": "2.6.0-subduction.26",
  "description": "Automerge Repo monorepo",
  "main": "packages/automerge-repo/dist/index.js",
  "repository": "https://github.com/automerge/automerge-repo",
  "author": "Peter van Hardenberg <pvh@pvh.ca>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev:demo": "pnpm -F @automerge/automerge-repo-demo-todo dev",
    "dev:svelte-demo": "pnpm -F @automerge/automerge-repo-demo-counter-svelte dev",
    "dev": "run-p watch start:syncserver dev:demo",
    "pub": "pnpm publish -r",
    "start:syncserver": "cross-env DEBUG='WebsocketServer' pnpm -F @automerge/example-sync-server start",
    "preinstall": "npx only-allow pnpm",
    "repocheck": "manypkg check",
    "format": "oxfmt",
    "lint": "oxfmt --check . && oxlint && pnpm run lint:check-types",
    "test": "vitest",
    "test:log": "cross-env DEBUG='automerge-repo:*' vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --coverage --ui",
    "watch": "pnpm run --parallel --stream -r watch ",
    "lint:check-types": "pnpm run lint:check-types:packages",
    "lint:check-types:packages": "pnpm --filter './packages/*' exec tsc --noEmit"
  },
  "engines": {
    "node": ">=22.13",
    "pnpm": "^11"
  },
  "packageManager": "pnpm@11.5.0",
  "devDependencies": {
    "@automerge/automerge": "^3.2.6",
    "@automerge/automerge-subduction": "0.13.0",
    "@manypkg/cli": "^0.25.1",
    "@playwright/test": "^1.60.0",
    "@types/debug": "^4.1.13",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "c8": "^7.14.0",
    "cross-env": "^10.1.0",
    "dev-null-cli": "^2.0.0",
    "fake-indexeddb": "6.2.5",
    "globals": "^15.6.0",
    "happy-dom": "^20.9.0",
    "lerna": "^9.0.4",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "portfinder": "^1.0.38",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "happy-dom": "^20.0.10"
  }
}
